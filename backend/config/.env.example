DATABASE_URL=postgresql://hr_agent:hr_agent@postgres:5432/hr_agent
POSTGRES_CREATE_HNSW_INDEX=false
VECTORSTORE_PROVIDER=postgres_pgvector
VECTOR_COLLECTION_PREFIX=hr_agent_kb

LLM_PROVIDER=bosch_openai_compatible
CHAT_API_ENDPOINT=https://aigc.bosch.com.cn/llmservice/api/v1/chat/completions
MODEL_API_AUTH_MODE=bearer
MODEL_API_KEY_HEADER_NAME=Authorization
CHAT_API_KEY=

DEFAULT_CHAT_MODEL=deepseek-v4-pro
PROFILE_MODEL=deepseek-v4-pro
INTENT_MODEL=deepseek-v4-pro
EMPLOYEE_MODEL=deepseek-v4-pro
GUIDANCE_MODEL=deepseek-v4-pro
COACH_EVALUATOR_MODEL=deepseek-v4-pro
COACH_REDLINE_MODEL=deepseek-v4-pro
COACH_REPORT_MODEL=deepseek-v4-pro

EMBEDDING_PROVIDER=bosch
EMBEDDING_API_ENDPOINT=https://aigc.bosch.com.cn/llmservice/api/v2/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3

RERANK_PROVIDER=bosch
RERANK_API_ENDPOINT=https://aigc.bosch.com.cn/llmservice/api/v1/rerank
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank

MINERU_ENABLED=false
MINERU_COMMAND=mineru
MINERU_EXTRA_ARGS=
MINERU_TIMEOUT_SECONDS=1800
MINERU_FAIL_ON_ERROR=true

KB_INGEST_BATCH_SIZE=10
KB_CHUNK_SIZE=800
KB_CHUNK_OVERLAP=120
KB_INDEX_VERSION=v1

LLM_TEMPERATURE=0.1
LLM_EMPLOYEE_TEMPERATURE=0.4
LLM_PROFILE_MAX_TOKENS=8192
LLM_INTENT_MAX_TOKENS=4096
LLM_EMPLOYEE_MAX_TOKENS=0
LLM_GUIDANCE_MAX_TOKENS=4096
LLM_COACH_EVALUATOR_MAX_TOKENS=8192
LLM_COACH_REDLINE_MAX_TOKENS=8192
LLM_COACH_REPORT_MAX_TOKENS=10000
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_RESPONSE_FORMAT_STYLE=openai
LANGCHAIN_STRUCTURED_OUTPUT_STRATEGY=provider
MAX_USER_TURNS=0
ENABLE_TRACE=false

# =========================
# Redis Cache
# =========================
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_KEY_PREFIX=hragent05
REDIS_CONNECT_TIMEOUT_SECONDS=1
REDIS_SOCKET_TIMEOUT_SECONDS=1
GUIDANCE_CACHE_TTL_SECONDS=21600
TTS_CACHE_TTL_SECONDS=604800
DOCUMENT_PARSE_CACHE_TTL_SECONDS=2592000
REHEARSAL_AUX_CACHE_TTL_SECONDS=3600
MINERU_API_URL=http://mineru:8000
MINERU_BACKEND=hybrid-engine
MINERU_EFFORT=high
MINERU_PARSE_METHOD=auto
MINERU_LANG=ch

# =========================
# ASR / Speech-to-Text
# =========================
ASR_ENABLED=true
ASR_PROVIDER=qwen
ASR_MODEL=qwen3-asr-flash-realtime
ASR_API_KEY=
ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ASR_HTTP_URL=https://aigc.bosch.com.cn/llmservice/api/v1/audio/transcriptions
ASR_HTTP_MODEL=qwen3-asr-flash
ASR_LANGUAGE=zh
ASR_SAMPLE_RATE=16000
ASR_INPUT_AUDIO_FORMAT=pcm
ASR_ENABLE_SERVER_VAD=true
ASR_VAD_THRESHOLD=0.0
ASR_VAD_SILENCE_DURATION_MS=400
ASR_CONNECT_TIMEOUT_SECONDS=15
ASR_SESSION_TIMEOUT_SECONDS=120
ASR_MAX_SESSION_SECONDS=300

ASR_MAX_AUDIO_SECONDS=60
ASR_MAX_AUDIO_MB=20

# Emotion Engine
EMOTION_ENGINE_ENABLED=true
EMOTION_ANALYZER_PROVIDER=rules
EMOTION_ANALYZER_MODEL=qwen-plus
EMOTION_HISTORY_WINDOW=5
EMOTION_STATE_MAX_INTENSITY=75
EMOTION_STATE_ANTI_JUMP=true

# =========================
# TTS / Text-to-Speech
# =========================
TTS_ENABLED=true
TTS_PROVIDER=qwen
TTS_API_URL=https://aigc.bosch.com.cn/llmservice/api/v1/audio/speech
TTS_API_KEY=
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry
TTS_RESPONSE_FORMAT=mp3
TTS_SPEED=1.0
TTS_TIMEOUT_SECONDS=60
TTS_MAX_CHARS=2000

# LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hragent-05
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=hragent-05

# Coach report generation
COACH_FINAL_REPORT_TIMEOUT_SECONDS=2.5
# =========================
# Motivation / Dynamic Emotion Thresholds
# =========================
MOTIVATION_ENGINE_ENABLED=true
MOTIVATION_PRIMARY_WEIGHT=0.7
MOTIVATION_SECONDARY_WEIGHT=0.3


